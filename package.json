{
  "name": "patchpit",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=24.12.0"
  },
  "scripts": {
    "build": "pnpm --filter @patchpit/shell build",
    "claims:check": "node scripts/claims.mjs check",
    "claims:take": "node scripts/claims.mjs take",
    "dev": "pnpm --filter @patchpit/shell dev",
    "lint": "pnpm typecheck",
    "test": "vitest run tests/*.test.ts && pnpm --filter './apps/*' --if-present test",
    "typecheck": "tsc"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
