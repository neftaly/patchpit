{
  "name": "patchpit",
  "private": true,
  "version": "0.0.0",
  "license": "AGPL-3.0-only",
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=24.12.0"
  },
  "scripts": {
    "bench:connectors": "vitest run scripts/connector-ingest-bench.test.ts --reporter verbose",
    "bench:royal": "vitest run scripts/render-bench.spec.ts scripts/gltf-lifetime-bench.spec.ts --reporter verbose",
    "bench:royal:text": "vitest run scripts/royal-text-bench.test.ts --reporter verbose",
    "bench:tarstate": "pnpm build && vitest run scripts/tarstate-ux-bench.test.ts --reporter verbose",
    "bench:tarstate:columnar": "vitest run scripts/tarstate-columnar-source-bench.test.ts --reporter verbose",
    "bench:tarstate:geo": "vitest run scripts/tarstate-geo-bench.test.ts --reporter verbose",
    "bench:tarstate:memory": "vitest run scripts/tarstate-memory-bench.test.ts --reporter verbose --execArgv=--expose-gc",
    "build": "pnpm -r --if-present build",
    "check:gpu": "node scripts/gpu.ts check",
    "claims:check": "node scripts/claims.mjs check",
    "claims:clean": "node scripts/claims.mjs clean",
    "claims:status": "node scripts/claims.mjs status",
    "claims:take": "node scripts/claims.mjs take",
    "dev": "node scripts/dev-xr.mjs",
    "dev:all": "node scripts/dev-all.mjs",
    "dev:3d-viewer": "pnpm --filter @patchpit/3d-viewer dev",
    "dev:chargrid": "pnpm --filter @patchpit/chargrid-lab dev",
    "dev:infinigen": "pnpm --filter @patchpit/infinigen dev",
    "dev:shell": "pnpm --filter @patchpit/shell dev",
    "dev:royal": "pnpm --dir ../royal --filter @royal/examples-react dev",
    "dev:tarstate": "pnpm --filter @patchpit/tarstate-example dev",
    "lint": "pnpm typecheck && pnpm -r --if-present lint",
    "lan:url": "node scripts/lan-url.mjs",
    "preview:royal": "pnpm --dir ../royal --filter @royal/examples-react preview",
    "profile:gpu": "node scripts/gpu.ts profile",
    "quest:browser": "node scripts/quest-browser-control.mjs",
    "test": "vitest run scripts/gpu.test.ts tests/*.test.ts && pnpm --filter './apps/*' --if-present test && pnpm --filter './packages/*' --if-present test",
    "trace:summary": "node scripts/trace-summary.ts",
    "typecheck": "tsc"
  },
  "pnpm": {
    "overrides": {
      "@royal/renderer-core": "git+https://github.com/neftaly/royal.git#a762613a3aa00f2c923217e3e0c2f7536064ef7d&path:/packages/renderer-core",
      "@royal/react": "git+https://github.com/neftaly/royal.git#a762613a3aa00f2c923217e3e0c2f7536064ef7d&path:/packages/react-royal-fiber",
      "@royal/tarstate-lens": "git+https://github.com/neftaly/royal.git#a762613a3aa00f2c923217e3e0c2f7536064ef7d&path:/packages/royal-tarstate-lens",
      "@tarstate/core": "git+https://github.com/neftaly/royal.git#a762613a3aa00f2c923217e3e0c2f7536064ef7d&path:/packages/tarstate-core"
    }
  },
  "devDependencies": {
    "@royal/renderer-core": "git+https://github.com/neftaly/royal.git#a762613a3aa00f2c923217e3e0c2f7536064ef7d&path:/packages/renderer-core",
    "@royal/react": "git+https://github.com/neftaly/royal.git#a762613a3aa00f2c923217e3e0c2f7536064ef7d&path:/packages/react-royal-fiber",
    "@royal/tarstate-lens": "git+https://github.com/neftaly/royal.git#a762613a3aa00f2c923217e3e0c2f7536064ef7d&path:/packages/royal-tarstate-lens",
    "@tarstate/core": "git+https://github.com/neftaly/royal.git#a762613a3aa00f2c923217e3e0c2f7536064ef7d&path:/packages/tarstate-core",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "react": "^19.2.7",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-glsl": "catalog:",
    "vitest": "catalog:"
  }
}
