{
  "name": "patchpit",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build:royal": "pnpm --filter renderer build",
    "build": "pnpm --filter './packages/*' exec tsc && pnpm --filter './apps/*' build",
    "claims:check": "node scripts/claims.mjs check",
    "claims:take": "node scripts/claims.mjs take",
    "dev": "pnpm --filter @patchpit/shell dev",
    "dev:todo": "pnpm --filter @patchpit/todo-demo dev",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "pnpm --filter './apps/*' --filter './packages/*' exec oxlint --type-aware",
    "lint:fix": "pnpm --filter './apps/*' --filter './packages/*' exec oxlint --type-aware --fix",
    "preview": "pnpm --filter @patchpit/shell preview",
    "test": "pnpm build && node scripts/smoke.mjs",
    "typecheck": "pnpm --filter './apps/*' --filter './packages/*' exec tsc"
  },
  "devDependencies": {
    "playwright": "catalog:",
    "prettier": "catalog:"
  }
}
